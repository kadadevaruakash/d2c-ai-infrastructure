# ============================================================
# D2C AI Infrastructure — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── INFRASTRUCTURE ──────────────────────────────────────────

# Supabase (shared across all workflows)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── AI ───────────────────────────────────────────────────────

# OpenAI (primary AI provider)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (optional: use for higher quality outputs)
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone (RAG vector store — S-02)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=d2c-support-kb
PINECONE_ENVIRONMENT=us-east1-gcp

# ── E-COMMERCE ───────────────────────────────────────────────

# Shopify
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ── COMMUNICATION ────────────────────────────────────────────

# Brevo / Sendinblue (email sending)
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=hello@yourbrand.com
BREVO_FROM_NAME=Your Brand

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ── WHATSAPP OPS PHONES (stored in tenant_config, listed here as reference) ─
# These are stored per-tenant in the tenant_config table, NOT in .env.
# Listed here so you know what fields to populate during onboarding.
#
# tenant_config.sales_rep_phone       → Scenario 1: hot lead alerts, Scenario 2: email reply alerts, SC-03 handoff
# tenant_config.sales_lead_phone      → Scenario 5: cold lead digest
# tenant_config.content_manager_phone → Scenario 4: SEO draft approval
# tenant_config.ops_phone             → General ops alerts (replaces Slack #general)
# tenant_config.ceo_phone             → Escalations, revenue alerts (already exists)
# tenant_config.ig_page_id            → Scenario 3: Instagram DM replies (page IGSID)
# tenant_config.ig_page_token         → Scenario 3: Instagram page access token

# Meta Webhook Verification Token (shared across WhatsApp + Instagram webhooks)
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token

# Slack — REMOVED (replaced by WhatsApp)
# SLACK_BOT_TOKEN and SLACK_SIGNING_SECRET are no longer used.

# ── SOCIAL & ANALYTICS ──────────────────────────────────────

# Instagram / Meta Graph API
INSTAGRAM_ACCESS_TOKEN=your-ig-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-id
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Google (Analytics, Sheets, My Business)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GA4_PROPERTY_ID=your-ga4-property-id
GOOGLE_SHEETS_DOC_ID=your-google-sheets-doc-id

# Google My Business (for review alerts)
GMB_ACCOUNT_ID=your-gmb-account-id
GMB_LOCATION_ID=your-gmb-location-id

# ── BRAND-SPECIFIC (PER TENANT) ─────────────────────────────
# These are stored in tenant_config table, not .env
# Listed here only as reference for initial setup

# Per-tenant config stored in tenant_config table (reference only):
# ceo_phone              = +15551234567
# sales_rep_phone        = +15559876543
# sales_lead_phone       = +15551112222
# content_manager_phone  = +15553334444
# ops_phone              = +15555556666
# store_url              = https://yourstore.com
# calendly_url           = https://calendly.com/yourlink
# ig_page_id             = 123456789
# ig_page_token          = EAAxxxx...

# ── OPTIONAL INTEGRATIONS ────────────────────────────────────

# Amazon (SP-API — for C-03 listing optimization)
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_SELLER_ID=your-seller-id
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER   # US marketplace

# Calendly (webhook for booking confirmations)
CALENDLY_API_KEY=your-calendly-key
CALENDLY_USER_URI=https://api.calendly.com/users/your-user-id

# ── SECURITY ─────────────────────────────────────────────────

# Webhook signature verification
WEBHOOK_SECRET=your-32-char-random-secret

# API auth for /api/* endpoints
API_SECRET_KEY=your-internal-api-key

# ── RUNTIME ──────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
LOG_LEVEL=info
